# BPA_DataCentric profile: prod

PROJECT_ROOT=/srv/botsquad
DATACENTRIC_ROOT=${PROJECT_ROOT}/BPA_DataCentric

# Data paths
QUERYS_TITANIA_DIR=${DATACENTRIC_ROOT}/data/querys/titania
QUERYS_ONNET_DIR=${DATACENTRIC_ROOT}/data/querys/onnet
OUTPUTS_TITANIA_DIR=${DATACENTRIC_ROOT}/data/outputs/titania
OUTPUTS_ONNET_DIR=${DATACENTRIC_ROOT}/data/outputs/onnet
PARAM_TITANIA_DIR=${DATACENTRIC_ROOT}/data/parametros/titania
PARAM_ONNET_DIR=${DATACENTRIC_ROOT}/data/parametros/onnet

# Runtime
PROCESS_MONITOR_PORT=5052
PROCESS_MONITOR_API_BASE_URL=http://monitor-backend:5052
EXPORT_ENABLE_LOCK=true
FRONTEND_PUBLIC_PORT=5173
VITE_API_BASE_URL=http://localhost:5052

# Python runtime (container default)
UNIFIED_PYTHON=python
TITANIA_PYTHON=python
ONNET_PYTHON=python

# Blob (set via secure runtime, do not commit real values)
AZURE_BLOB_ACCOUNT_URL=
AZURE_BLOB_CONTAINER=site-reporting
AZURE_BLOB_SAS_TOKEN=
